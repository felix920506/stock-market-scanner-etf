# stock-ta backend (required for TA analysis)
# HTTP server:  STOCK_TA=http://localhost:8000
# CLI script:   STOCK_TA=/path/to/stock-ta/analyze_stock.py
# CLI binary:   STOCK_TA=/usr/local/bin/stock-ta
STOCK_TA=http://localhost:8000

# Recommendation history storage
# Defaults to ./data/scanner-history.sqlite3 when unset
# MARKET_SCANNER_HISTORY_PATH=./data/scanner-history.sqlite3

# Discord webhook URL (required for report delivery)
# To post into a thread, append ?thread_id=<id> to the URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
